# JIRA MCP Skill Configuration
# Copy this file to .env and fill in your values

# JIRA Server URL
JIRA_BASE_URL=https://your-jira-url/jira

# Authentication Method 1: Cookies (Recommended for SSO)
# Get from browser: F12 -> Network -> click any /rest/api/ request -> copy Cookie header
JIRA_COOKIES=JSESSIONID=xxx; atlassian.xsrf.token=xxx;

# Authentication Method 2: Bearer Token
# Get from browser: F12 -> Network -> find request with Authorization header
# JIRA_AUTH_TOKEN=Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Authentication Method 3: API Token (for Jira Cloud)
# JIRA_EMAIL=your-email@example.com
# JIRA_API_TOKEN=your-api-token
