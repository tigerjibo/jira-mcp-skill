# JIRA MCP Skill Configuration
# Copy this file to .env and fill in your values

# JIRA Server URL
JIRA_BASE_URL=https://your-jira-url/jira

# Authentication Method 1: Cookies (Recommended for SSO)
# Required cookie fields:
#   - JSESSIONID: Session ID (path must be /jira)
#   - atlassian.xsrf.token: Must end with _lin (not _lout, which means logged out)
#   - seraph.rememberme.cookie: Only present when "Remember Me" is checked during login
#   - ngx_jira: Load balancer routing (recommended)
#
# How to get cookies:
#   1. Login to JIRA in browser (CHECK "Remember Me")
#   2. Press F12 -> Application -> Cookies -> select JIRA domain
#   3. Copy the required cookies in key=value format separated by ;
JIRA_COOKIES=JSESSIONID=xxx; atlassian.xsrf.token=xxx_lin; seraph.rememberme.cookie=xxx; ngx_jira=xxx

# Authentication Method 2: Bearer Token
# Get from browser: F12 -> Network -> find request with Authorization header
# JIRA_AUTH_TOKEN=Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Authentication Method 3: API Token (for Jira Cloud)
# JIRA_EMAIL=your-email@example.com
# JIRA_API_TOKEN=your-api-token
